# Optional. When set, the site reads Convex overrides and articles. Without
# it, every page falls back to the static content in src/lib/content.ts.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Required for the /contact form to send mail via Resend.
# Get one from https://resend.com/api-keys
RESEND_API_KEY=re_replace_with_real_key
